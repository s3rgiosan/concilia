# Path to receipts folder on the HOST machine (mounted into container at /receipts)
# IMPORTANT: Use absolute paths — Docker does not expand ~ (tilde).
# Examples:
#   macOS:    /Users/yourname/Library/CloudStorage/Dropbox/Receipts
#   Linux:    /home/yourname/Dropbox/Receipts
#   Synology: /volume1/Receipts
RECEIPTS_PATH=/Users/yourname/Library/CloudStorage/Dropbox/Receipts

# Timezone (IANA format)
# https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Lisbon

# Host port (default: 3000)
# PORT=3000

# Google Gemini via Vertex AI (required)
# 1. Create a GCP project at https://console.cloud.google.com
# 2. Enable the Vertex AI API
# 3. Create a service account with "Vertex AI User" role
# 4. Download the JSON key and set the path below
AI_GEMINI_SA_KEY=/path/to/service-account-key.json

# GCP project ID (auto-detected from service account key if omitted)
# AI_GEMINI_PROJECT=your-project-id

# GCP region (default: europe-west1)
# AI_GEMINI_LOCATION=europe-west1

# Gemini model (optional, default: gemini-2.5-flash)
# AI_GEMINI_MODEL=gemini-2.5-flash

# SQLite database path (default: /data/concilia.db, mapped via docker-compose volume)
# DATABASE_PATH=/data/concilia.db

# External access — no additional config needed for reverse proxy
